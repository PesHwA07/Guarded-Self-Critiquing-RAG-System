# ============================================
# Guarded RAG System — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets!
# ============================================

# --- LLM Provider ---
# Options: "groq" (default, free tier) or "ollama" (local, needs GPU)
LLM_PROVIDER=groq

# --- Groq API ---
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Generator model (fast, cheap)
GROQ_GENERATOR_MODEL=llama-3.1-8b-instant

# Critic model (stronger, catches generator's mistakes)
GROQ_CRITIC_MODEL=llama-3.3-70b-versatile

# --- Ollama (optional, local) ---
# Only needed if LLM_PROVIDER=ollama
# Install: https://ollama.com/download
# Pull model: ollama pull llama3.1:8b-instruct-q4_K_M
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_BASE_URL=http://localhost:11434

# --- Embeddings ---
# Local model, no API key needed
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- RAG Settings ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
MAX_RETRIES=2

# --- LangSmith (optional tracing) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=guarded-rag-system
